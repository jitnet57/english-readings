# Translation API Keys

# 1️⃣ Google Translate (데모 번역 - API 키 불필요)
# 자동으로 작동하는 데모 번역입니다

# 2️⃣ Gemma 2 (E2B) - 권장
# https://e2b.dev 에서 무료 API 키 생성
REACT_APP_E2B_API_KEY=your_e2b_api_key

# 3️⃣ Claude API (Anthropic)
# https://console.anthropic.com/ 에서 API 키 생성
REACT_APP_ANTHROPIC_API_KEY=your_claude_api_key

# 4️⃣ OpenAI API
# https://platform.openai.com/api-keys 에서 API 키 생성
REACT_APP_OPENAI_API_KEY=your_openai_api_key

# 5️⃣ DeepL API (고품질 번역)
# https://www.deepl.com/docs-api 에서 API 키 생성
REACT_APP_DEEPL_API_KEY=your_deepl_api_key

# Default Translation API (google, gemma, claude, openai, deepl)
REACT_APP_DEFAULT_TRANSLATION_API=google
