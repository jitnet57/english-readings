# Stale compiled JS (이번 프로젝트의 유령 버그 주범 — 절대 커밋 금지)
# .ts/.tsx의 컴파일 결과물이 src/루트에 생기면 새 코드를 가림
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
vite.config.js
vite.config.d.ts
# 단, 정상 설정 파일(.ts 짝 없음)은 추적 유지
!postcss.config.js
!tailwind.config.js

